{
  "name": "Apply Flow",
  "description": "Helps to apply jobs automatically",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "/popup/popup.html",
    "default_icon": "images/logo.png"
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["libs/dexie.min.js", "scripts/content.js"]
    }
  ]
}